# 复制本文件为 .env，并填入真实值
# 本地开发：spring-dotenv 按 application.yml 的 dotenv.directory 查找，
#           已配置为 ${user.dir}/server，即项目根下的 server/.env
# 服务端部署：docker run --env-file .env（用真实环境变量，不依赖 .env 文件）

DB_HOST=localhost
DB_PORT=5432
DB_NAME=swim
DB_USERNAME=football
DB_PASSWORD=

# JWT 密钥（至少 256 位的随机字符串）
JWT_SECRET=

# 微信小程序配置
WX_APPID=
WX_SECRET=
